    "EBAY_PLATFORM_ENDPOINT_URL": "https://<app>.azurewebsites.net/api/ebay/notifications",

    "_comment": "Optional: set the two below to enable x-ebay-signature verification.",
    "EBAY_CLIENT_ID": "",
    "EBAY_CLIENT_SECRET": ""
  }
}
